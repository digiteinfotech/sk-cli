# SwiftKanban API Token (JWT Bearer token)
SK_TOKEN=

# SwiftKanban server URL (default: https://webapi.swiftkanban.com)
SK_SERVER=https://login.swiftkanban.com

# Default board ID (optional, avoids passing --board-id every time)
SK_BOARD_ID=

# User credentials (alternative to SK_TOKEN — used to generate JWT)
SK_USER=
SK_PASSWORD=
